{
  "name": "dijital-pati",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "npm run dev --workspace=apps/next",
    "mobile": "npm run start --workspace=apps/expo",
    "dev": "concurrently \"npm run web\" \"npm run mobile\"",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@expo/config-plugins": "~54.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-module-resolver": "^5.0.3",
    "concurrently": "^8.2.2",
    "expo": "~54.0.0"
  },
  "overrides": {
    "ajv": "^8.12.0",
    "ajv-keywords": "^5.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "dependencies": {
    "expo-dev-client": "~6.0.20",
    "react-native-reanimated": "^4.3.0",
    "react-native-worklets-core": "^1.6.3"
  }
}
