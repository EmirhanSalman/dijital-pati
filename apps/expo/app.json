{
  "expo": {
    "name": "Dijital Pati",
    "slug": "dijital-pati",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Dijital Pati, kayıp hayvan haritasında konumunuzu göstermek için konum erişimi kullanır.",
        "NSCameraUsageDescription": "Dijital Pati, evcil hayvan künyesindeki QR kodu okutmak için kameraya erişir."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "scheme": "dijitalpati",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Dijital Pati, kayıp hayvan haritasında konumunuzu göstermek için konum erişimi kullanır."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Dijital Pati, evcil hayvan künyesindeki QR kodu okutmak için kameraya erişir."
        }
      ]
    ]
  }
}
