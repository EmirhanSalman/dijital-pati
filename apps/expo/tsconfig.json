{
  "extends": "../../node_modules/expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "jsxImportSource": "nativewind",
    "types": [
      "nativewind/types",
      "expo-router/types"
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@dijital-pati/app/*": [
        "../../packages/app/*"
      ],
      "expo-router/types": [
        "../../node_modules/expo-router/types"
      ],
      "nativewind/types": [
        "../../node_modules/nativewind/types"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "app-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
